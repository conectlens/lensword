# Copy this file to .env and adjust as needed.
DATABASE_URL=sqlite:///./data/lensword.db
SECRET_KEY=change-me-to-a-long-random-value-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# Optional: auto-create an admin account on first startup
FIRST_ADMIN_EMAIL=
FIRST_ADMIN_PASSWORD=

# Optional: local AI mnemonic suggestions via Ollama. Leave AI_PROVIDER as
# "none" to keep the feature off entirely. See the README for setup.
AI_PROVIDER=none
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
